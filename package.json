{
  "name": "sun-panel-worker",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute sun-panel-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute sun-panel-db --file=./schema.sql --local",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "vue-demi"
    ]
  },
  "dependencies": {
    "hono": "^4.7.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250605.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1",
    "wrangler": "^4.0.0"
  }
}
